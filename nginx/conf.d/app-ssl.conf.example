# Optional: HTTPS + real domain. Requires certbot/Let's Encrypt and extra compose volumes.
# Copy to app-ssl.conf after certs exist, add listen 443 and cert paths, then reload nginx.

server {
    listen 443 ssl;
    server_name kirillblog.ru;

    resolver 127.0.0.11 valid=10s;
    set $upstream backend:8000;

    ssl_certificate /etc/letsencrypt/live/kirillblog.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/kirillblog.ru/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    location / {
        proxy_pass http://$upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
    }
}
